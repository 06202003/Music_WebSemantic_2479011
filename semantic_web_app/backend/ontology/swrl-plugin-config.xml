<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plugin PUBLIC "-//PROTEGE//DTD PLUGIN//EN" "http://protege.stanford.edu/dtd/plugin.dtd">

<plugin>
  <name>SWRL Rules Editor</name>
  <version>1.0</version>
  <author>Stanford University</author>
  <description>SWRL (Semantic Web Rule Language) tab for Protege OWL Editor</description>
  
  <extension-point id="TabPlugin" name="Tab Plugin">
    <plugin-class value="org.protege.editor.owl.ui.view.SWRLRulesView"/>
    <label>SWRL Rules</label>
    <icon>SWRLTab.gif</icon>
    <tooltip>View and edit SWRL rules</tooltip>
    <default-tab-index>5</default-tab-index>
    <ordering>after=OWLClassHierarchyTab</ordering>
  </extension-point>

  <extension-point id="SWRLVisualization" name="SWRL Visualization">
    <plugin-class value="org.protege.editor.owl.ui.renderer.SWRLRuleRenderer"/>
    <label>SWRL Rule Renderer</label>
  </extension-point>

  <requires plugin="protege.editor.owl" min-version="5.0.0" />
  <requires plugin="org.protege.editor.core" min-version="5.0.0" />
</plugin>
