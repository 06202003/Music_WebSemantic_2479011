<?xml version="1.0"?>
<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:music="http://example.org/music#">

  <owl:Ontology rdf:about="http://example.org/music"/>

  <!-- Classes -->
  <owl:Class rdf:about="http://example.org/music#Song"/>
  <owl:Class rdf:about="http://example.org/music#Artist"/>
  <owl:Class rdf:about="http://example.org/music#Album"/>
  <owl:Class rdf:about="http://example.org/music#Genre"/>
  <owl:Class rdf:about="http://example.org/music#Country"/>

  <!-- Properties -->
  <owl:ObjectProperty rdf:about="http://example.org/music#performedBy">
    <rdfs:domain rdf:resource="http://example.org/music#Song"/>
    <rdfs:range rdf:resource="http://example.org/music#Artist"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://example.org/music#partOfAlbum">
    <rdfs:domain rdf:resource="http://example.org/music#Song"/>
    <rdfs:range rdf:resource="http://example.org/music#Album"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://example.org/music#hasGenre">
    <rdfs:domain rdf:resource="http://example.org/music#Song"/>
    <rdfs:range rdf:resource="http://example.org/music#Genre"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://example.org/music#collaboratesWith">
    <rdfs:domain rdf:resource="http://example.org/music#Artist"/>
    <rdfs:range rdf:resource="http://example.org/music#Artist"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://example.org/music#fromCountry">
    <rdfs:domain rdf:resource="http://example.org/music#Artist"/>
    <rdfs:range rdf:resource="http://example.org/music#Country"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://example.org/music#relatedByArtist">
    <rdfs:domain rdf:resource="http://example.org/music#Song"/>
    <rdfs:range rdf:resource="http://example.org/music#Song"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://example.org/music#frequentCollaborator">
    <rdfs:domain rdf:resource="http://example.org/music#Artist"/>
    <rdfs:range rdf:resource="http://example.org/music#Artist"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="http://example.org/music#releaseYear">
    <rdfs:domain rdf:resource="http://example.org/music#Song"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://example.org/music#title">
    <rdfs:domain rdf:resource="http://example.org/music#Song"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://example.org/music#collaborationType">
    <rdfs:domain rdf:resource="http://example.org/music#Song"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://example.org/music#artistName">
    <rdfs:domain rdf:resource="http://example.org/music#Artist"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://example.org/music#countryName">
    <rdfs:domain rdf:resource="http://example.org/music#Country"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://example.org/music#source">
    <rdfs:domain rdf:resource="http://example.org/music#Song"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://example.org/music#fetchedAt">
    <rdfs:domain rdf:resource="http://example.org/music#Song"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://example.org/music#collaborationFrequency">
    <rdfs:domain rdf:resource="http://example.org/music#Artist"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </owl:DatatypeProperty>

</rdf:RDF>
