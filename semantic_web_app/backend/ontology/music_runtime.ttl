@prefix : <http://example.org/music#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix swrl: <http://www.w3.org/2003/11/swrl#> .
@prefix swrlb: <http://www.w3.org/2003/11/swrlb#> .
@prefix music: <http://example.org/music#> .
@base <http://example.org/music#> .

music:MusicOntology rdf:type owl:Ontology ;
                    rdfs:label "Semantic Music Runtime Ontology" ;
                    rdfs:comment "Runtime ontology for music knowledge graph with OWL reasoning, SWRL rules, and SPARQL examples." ;
                    music:internalSparqlExample """# Internal (API / application)
CONSTRUCT {
  ?song music:performedBy ?artist .
  ?artist music:artistName ?artistName .
}
WHERE {
  ?song a music:Song ;
        music:performedBy ?artist .
  OPTIONAL { ?artist music:artistName ?artistName . }
}
LIMIT 30

ASK {
  ?song a music:Song ;
        music:collaborationType ?type .
}

DESCRIBE ?song
WHERE { ?song a music:Song }
LIMIT 1""" ;
                    music:externalSparqlExample """# External (Protege SPARQL tab / RDF4J)
PREFIX music: <http://example.org/music#>

CONSTRUCT {
  ?a music:collaboratesWith ?b .
}
WHERE {
  ?s1 a music:Song ; music:performedBy ?a .
  ?s2 a music:Song ; music:performedBy ?a ; music:performedBy ?b .
  FILTER(?a != ?b)
}
LIMIT 50

PREFIX music: <http://example.org/music#>
ASK {
  ?artist a music:ConcertArtist .
}

PREFIX music: <http://example.org/music#>
DESCRIBE ?artist
WHERE { ?artist a music:Artist }
LIMIT 2""" .

#################################################################
#    Annotation Properties
#################################################################

###  http://example.org/music#externalSparqlExample
music:externalSparqlExample rdf:type owl:AnnotationProperty .


###  http://example.org/music#internalSparqlExample
music:internalSparqlExample rdf:type owl:AnnotationProperty .


###  http://example.org/music#sparqlQueryPackage
music:sparqlQueryPackage rdf:type owl:AnnotationProperty .

music:MusicOntology music:sparqlQueryPackage """
###################################################################
# SPARQL QUERY PACKAGE - TEST INFERENCE RULES
# Copy & paste these queries into Protege SPARQL tab to test all inference
###################################################################

# ===== 1. TEST CLASSIC SONG CLASSIFICATION (releaseYear <= 2005) =====
PREFIX music: <http://example.org/music#>

ASK {
  music:Song_demo_timeless_echo a music:ClassicSong .
}
# Expected: TRUE (from rule_classicSongClassification, 1999 <= 2005)

---

PREFIX music: <http://example.org/music#>

DESCRIBE music:Song_demo_timeless_echo
# Shows: All properties + ClassicSong class inferred

---

PREFIX music: <http://example.org/music#>

SELECT ?song ?year ?genres WHERE {
  ?song a music:ClassicSong ;
        music:releaseYear ?year ;
        music:hasGenre ?genres .
}
# Lists all songs inferred as ClassicSong with their year and genres

---

# ===== 2. TEST TRENDING SONG CLASSIFICATION (popularityScore > 80) =====
PREFIX music: <http://example.org/music#>

ASK {
  music:Song_demo_viral_current a music:TrendingSong .
  music:Song_demo_timeless_echo a music:TrendingSong .
}
# Expected: TRUE (both have popularity > 80)

---

PREFIX music: <http://example.org/music#>

SELECT ?song ?popularity WHERE {
  ?song a music:TrendingSong ;
        music:popularityScore ?popularity .
}
ORDER BY DESC(?popularity)
# Lists trending songs by popularity score (descending)

---

# ===== 3. TEST HIT SONG CLASSIFICATION (TrendingSong + durationSeconds > 180) =====
PREFIX music: <http://example.org/music#>

ASK {
  music:Song_demo_viral_current a music:HitSong .
}
# Expected: TRUE (Trending AND 245 seconds > 180)

---

PREFIX music: <http://example.org/music#>

DESCRIBE music:Song_demo_viral_current
# Shows: All properties + TrendingSong + HitSong classes inferred

---

PREFIX music: <http://example.org/music#>

SELECT ?song ?duration ?popularity ?year WHERE {
  ?song a music:HitSong ;
        music:durationSeconds ?duration ;
        music:popularityScore ?popularity ;
        music:releaseYear ?year .
}
# Lists all HitSongs with their characteristics

---

# ===== 4. TEST RECOMMENDED SONGS BY MOOD (recommendedWith inference) =====
PREFIX music: <http://example.org/music#>

ASK {
  music:Song_demo_reflection music:recommendedWith music:Song_demo_reflection_live .
}
# Expected: TRUE (both share mood: reflective)

---

PREFIX music: <http://example.org/music#>

SELECT ?song1 ?song2 ?mood WHERE {
  ?song1 a music:Song ;
         music:hasMood ?mood ;
         music:recommendedWith ?song2 .
  ?song2 music:hasMood ?mood .
}
# Shows recommendation pairs grouped by shared mood

---

PREFIX music: <http://example.org/music#>

CONSTRUCT {
  ?song1 music:recommendedWith ?song2 .
  ?song1 rdfs:label ?label1 .
  ?song2 rdfs:label ?label2 .
}
WHERE {
  ?song1 music:recommendedWith ?song2 .
  OPTIONAL { ?song1 rdfs:label ?label1 . }
  OPTIONAL { ?song2 rdfs:label ?label2 . }
}
# Builds recommendation graph with labels

---

# ===== 5. TEST COLLABORATIVE ARTIST INFERENCE =====
PREFIX music: <http://example.org/music#>

ASK {
  music:Artist_demo_solo a music:CollaborativeArtist .
  music:Artist_demo_band a music:CollaborativeArtist .
}
# Expected: TRUE (both collaborated on Song_demo_collab_bridge)

---

PREFIX music: <http://example.org/music#>

SELECT ?artist ?collaborators ?collabCount WHERE {
  ?artist a music:CollaborativeArtist .
  {
    SELECT ?artist (COUNT(?other) as ?collabCount) WHERE {
      ?artist music:collaboratesWith ?other .
    }
    GROUP BY ?artist
  }
}
# Lists collaborative artists with collaboration count

---

PREFIX music: <http://example.org/music#>

CONSTRUCT {
  ?a1 music:collaboratesWith ?a2 .
  ?a1 music:artistName ?name1 .
  ?a2 music:artistName ?name2 .
}
WHERE {
  ?a1 a music:CollaborativeArtist ;
      music:collaboratesWith ?a2 ;
      music:artistName ?name1 .
  ?a2 music:artistName ?name2 .
}
# Builds collaboration network graph

---

# ===== 6. TEST MULTI-GENRE ALBUM INFERENCE =====
PREFIX music: <http://example.org/music#>

ASK {
  ?album a music:MultiGenreAlbum .
}
# Expected: TRUE if any album inferred to have 2+ genres

---

PREFIX music: <http://example.org/music#>

SELECT ?album ?genreCount ?genres WHERE {
  ?album a music:MultiGenreAlbum .
  {
    SELECT ?album (COUNT(DISTINCT ?genre) as ?genreCount) 
           (GROUP_CONCAT(DISTINCT ?genreName; separator=\", \") as ?genres) WHERE {
      ?album music:albumPrimaryGenre ?genre .
      ?genre rdfs:label ?genreName .
    }
    GROUP BY ?album
  }
}
# Lists multi-genre albums with genre count

---

PREFIX music: <http://example.org/music#>

DESCRIBE ?album
WHERE {
  ?album a music:MultiGenreAlbum .
}
LIMIT 1
# Shows first MultiGenreAlbum with all inferred properties

---

# ===== 7. TEST ARTIST CLASS FROM COLLABORATION =====
PREFIX music: <http://example.org/music#>

ASK {
  ?artist a music:Artist ;
          music:collaboratesWith ?other .
  FILTER(?artist = music:Artist_demo_solo || ?artist = music:Artist_demo_band)
}
# Expected: TRUE (both have collaboratesWith property)

---

# ===== 8. TEST ALBUM-ARTIST INFERENCE =====
PREFIX music: <http://example.org/music#>

SELECT ?album ?artist ?artistName WHERE {
  ?album music:albumByArtist ?artist .
  ?artist music:artistName ?artistName .
}
# Shows inferred album-artist relationships

---

# ===== 9. TEST ALBUM-GENRE INFERENCE =====
PREFIX music: <http://example.org/music#>

SELECT ?album ?genre ?genreLabel WHERE {
  ?album music:albumPrimaryGenre ?genre .
  OPTIONAL { ?genre rdfs:label ?genreLabel . }
}
# Shows inferred album-genre relationships

---

# ===== 10. COMPREHENSIVE INFERENCE SUMMARY =====
PREFIX music: <http://example.org/music#>

SELECT 
  (COUNT(DISTINCT ?classicsong) as ?classicSongCount)
  (COUNT(DISTINCT ?trendingsong) as ?trendingSongCount)
  (COUNT(DISTINCT ?hitsong) as ?hitSongCount)
  (COUNT(DISTINCT ?collarty) as ?collaborativeArtistCount)
  (COUNT(DISTINCT ?multialbum) as ?multiGenreAlbumCount)
WHERE {
  OPTIONAL { ?classicsong a music:ClassicSong . }
  OPTIONAL { ?trendingsong a music:TrendingSong . }
  OPTIONAL { ?hitsong a music:HitSong . }
  OPTIONAL { ?collarty a music:CollaborativeArtist . }
  OPTIONAL { ?multialbum a music:MultiGenreAlbum . }
}
# Aggregate counts of all inferred entities

---

# ===== 11. INFERENCE CHAIN VISUALIZATION =====
PREFIX music: <http://example.org/music#>

CONSTRUCT {
  ?song a ?class ;
        music:releaseYear ?year ;
        music:popularityScore ?pop ;
        music:durationSeconds ?dur ;
        music:title ?title .
}
WHERE {
  ?song a music:Song ;
        music:title ?title ;
        music:releaseYear ?year ;
        music:popularityScore ?pop ;
        music:durationSeconds ?dur .
  ?song a ?class .
  FILTER(?class IN (music:ClassicSong, music:TrendingSong, music:HitSong))
}
# Builds graph of all classified songs with their attributes

---

# ===== 12. EDGE CASE: Song with Multiple Classifications =====
PREFIX music: <http://example.org/music#>

SELECT ?song ?classes WHERE {
  ?song a music:Song .
  {
    SELECT ?song (GROUP_CONCAT(DISTINCT ?cls; separator=\" | \") as ?classes) WHERE {
      ?song a ?cls .
      FILTER(?cls IN (music:ClassicSong, music:TrendingSong, music:HitSong))
    }
    GROUP BY ?song
  }
}
# Shows songs with multiple classification triggers

---

# ===== USAGE NOTES =====
# 1. Paste each query block into Protege SPARQL tab (Tools > SPARQL Query)
# 2. Enable Reasoner first (Protege > Reasoner > HermiT / Pellet)
# 3. Click \"Execute\" to run each query
# 4. Results should show inferred classes and relationships
# 5. Without reasoner: queries return empty or only explicit triples
# 6. With reasoner: queries show all inferred conclusions from SWRL rules
""" .


#################################################################
#    Object Properties
#################################################################

###  http://example.org/music#collaboratesWith
music:collaboratesWith rdf:type owl:ObjectProperty ,
                                owl:SymmetricProperty ;
                       rdfs:domain music:Artist ;
                       rdfs:range music:Artist .


###  http://example.org/music#frequentCollaborator
music:frequentCollaborator rdf:type owl:ObjectProperty ;
                           rdfs:subPropertyOf music:collaboratesWith ;
                           rdfs:domain music:Artist ;
                           rdfs:range music:Artist .


###  http://example.org/music#fromCountry
music:fromCountry rdf:type owl:ObjectProperty ;
                  rdfs:domain music:Artist ;
                  rdfs:range music:Country .


###  http://example.org/music#hasGenre
music:hasGenre rdf:type owl:ObjectProperty ;
               rdfs:domain music:Song ;
               rdfs:range music:Genre .


###  http://example.org/music#partOfAlbum
music:partOfAlbum rdf:type owl:ObjectProperty ;
                  rdfs:domain music:Song ;
                  rdfs:range music:Album .


###  http://example.org/music#performedBy
music:performedBy rdf:type owl:ObjectProperty ;
                  owl:inverseOf music:performsSong ;
                  rdfs:domain music:Song ;
                  rdfs:range music:Artist .


###  http://example.org/music#performsSong
music:performsSong rdf:type owl:ObjectProperty ;
                   rdfs:domain music:Artist ;
                   rdfs:range music:Song .


###  http://example.org/music#relatedByArtist
music:relatedByArtist rdf:type owl:ObjectProperty ,
                               owl:SymmetricProperty ;
                      rdfs:domain music:Song ;
                      rdfs:range music:Song .

###  http://example.invalid/ontologies/ont.owl#performedSong
<http://example.invalid/ontologies/ont.owl#performedSong> rdf:type owl:ObjectProperty ;
                                                          rdfs:domain music:Event ;
                                                          rdfs:range music:Song .


###  http://example.invalid/ontologies/ont.owl#performsAt
<http://example.invalid/ontologies/ont.owl#performsAt> rdf:type owl:ObjectProperty ;
                                                       rdfs:domain music:Artist ;
                                                       rdfs:range music:Event .


#################################################################
#    Data Properties
#################################################################

###  http://example.org/music#artistName
music:artistName rdf:type owl:DatatypeProperty ;
                 rdfs:domain music:Artist ;
                 rdfs:range xsd:string .


###  http://example.org/music#collaborationFrequency
music:collaborationFrequency rdf:type owl:DatatypeProperty ;
                             rdfs:domain music:Artist ;
                             rdfs:range xsd:integer .


###  http://example.org/music#collaborationType
music:collaborationType rdf:type owl:DatatypeProperty ;
                        rdfs:domain music:Song ;
                        rdfs:range xsd:string .


###  http://example.org/music#countryName
music:countryName rdf:type owl:DatatypeProperty ;
                  rdfs:domain music:Country ;
                  rdfs:range xsd:string .


###  http://example.org/music#fetchedAt
music:fetchedAt rdf:type owl:DatatypeProperty ;
                rdfs:domain music:Song ;
                rdfs:range xsd:dateTime .


###  http://example.org/music#releaseYear
music:releaseYear rdf:type owl:DatatypeProperty ;
                  rdfs:domain music:Song ;
                  rdfs:range xsd:integer .


###  http://example.org/music#source
music:source rdf:type owl:DatatypeProperty ;
             rdfs:domain music:Song ;
             rdfs:range xsd:string .


###  http://example.org/music#title
music:title rdf:type owl:DatatypeProperty ;
            rdfs:domain music:Song ;
            rdfs:range xsd:string .


#################################################################
#    Classes
#################################################################

###  http://example.org/music#Album
music:Album rdf:type owl:Class .


###  http://example.org/music#Artist
music:Artist rdf:type owl:Class .


###  http://example.org/music#ConcertArtist
music:ConcertArtist rdf:type owl:Class ;
                    owl:equivalentClass [ owl:intersectionOf ( music:Artist
                                                               [ rdf:type owl:Restriction ;
                                                                 owl:onProperty <http://example.invalid/ontologies/ont.owl#performsAt> ;
                                                                 owl:someValuesFrom music:Event
                                                               ]
                                                             ) ;
                                          rdf:type owl:Class
                                        ] .


###  http://example.org/music#Country
music:Country rdf:type owl:Class .


###  http://example.org/music#Event
music:Event rdf:type owl:Class ;
            rdfs:subClassOf [ rdf:type owl:Restriction ;
                              owl:onProperty <http://example.invalid/ontologies/ont.owl#performedSong> ;
                              owl:someValuesFrom music:Song
                            ] .


###  http://example.org/music#Genre
music:Genre rdf:type owl:Class .


###  http://example.org/music#Song
music:Song rdf:type owl:Class ;
           rdfs:subClassOf [ rdf:type owl:Restriction ;
                             owl:onProperty music:performedBy ;
                             owl:someValuesFrom music:Artist
                           ] ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty music:hasGenre ;
                             owl:someValuesFrom music:Genre
                           ] .


###  http://example.org/music#BandArtist
music:BandArtist rdf:type owl:Class ;
                 rdfs:subClassOf music:Artist .


###  http://example.org/music#CollaborativeArtist
music:CollaborativeArtist rdf:type owl:Class ;
                          rdfs:subClassOf music:Artist .


###  http://example.org/music#Era
music:Era rdf:type owl:Class .


###  http://example.org/music#FestivalEvent
music:FestivalEvent rdf:type owl:Class ;
                    rdfs:subClassOf music:Event .


###  http://example.org/music#Language
music:Language rdf:type owl:Class .


###  http://example.org/music#LiveEvent
music:LiveEvent rdf:type owl:Class ;
                rdfs:subClassOf music:Event .


###  http://example.org/music#Mood
music:Mood rdf:type owl:Class .


###  http://example.org/music#MultiGenreAlbum
music:MultiGenreAlbum rdf:type owl:Class ;
                      rdfs:subClassOf music:Album .


###  http://example.org/music#ClassicSong
music:ClassicSong rdf:type owl:Class ;
                  rdfs:subClassOf music:Song .


###  http://example.org/music#TrendingSong
music:TrendingSong rdf:type owl:Class ;
                   rdfs:subClassOf music:Song .


###  http://example.org/music#HitSong
music:HitSong rdf:type owl:Class ;
              rdfs:subClassOf music:TrendingSong .


###  http://example.org/music#Playlist
music:Playlist rdf:type owl:Class .


###  http://example.org/music#SoloArtist
music:SoloArtist rdf:type owl:Class ;
                 rdfs:subClassOf music:Artist ;
                 owl:disjointWith music:BandArtist .


#################################################################
#    Additional Object Properties
#################################################################

###  http://example.org/music#belongsToEra
music:belongsToEra rdf:type owl:ObjectProperty ;
                   rdfs:domain music:Song ;
                   rdfs:range music:Era .


###  http://example.org/music#containsSong
music:containsSong rdf:type owl:ObjectProperty ;
                   rdfs:domain music:Playlist ;
                   rdfs:range music:Song .


###  http://example.org/music#curatedBy
music:curatedBy rdf:type owl:ObjectProperty ;
                rdfs:domain music:Playlist ;
                rdfs:range music:Artist .


###  http://example.org/music#albumByArtist
music:albumByArtist rdf:type owl:ObjectProperty ;
                    rdfs:domain music:Album ;
                    rdfs:range music:Artist .


###  http://example.org/music#albumPrimaryGenre
music:albumPrimaryGenre rdf:type owl:ObjectProperty ;
                        rdfs:domain music:Album ;
                        rdfs:range music:Genre .


###  http://example.org/music#featuredInEvent
music:featuredInEvent rdf:type owl:ObjectProperty ;
                      rdfs:domain music:Song ;
                      rdfs:range music:Event .


###  http://example.org/music#hasLanguage
music:hasLanguage rdf:type owl:ObjectProperty ;
                  rdfs:domain music:Song ;
                  rdfs:range music:Language .


###  http://example.org/music#hasMood
music:hasMood rdf:type owl:ObjectProperty ;
              rdfs:domain music:Song ;
              rdfs:range music:Mood .


###  http://example.org/music#hostCountry
music:hostCountry rdf:type owl:ObjectProperty ;
                  rdfs:domain music:Event ;
                  rdfs:range music:Country .


###  http://example.org/music#influencedBy
music:influencedBy rdf:type owl:ObjectProperty ;
                   rdfs:domain music:Artist ;
                   rdfs:range music:Artist .


###  http://example.org/music#sampledFrom
music:sampledFrom rdf:type owl:ObjectProperty ;
                  rdfs:domain music:Song ;
                  rdfs:range music:Song .


###  http://example.org/music#similarGenreTo
music:similarGenreTo rdf:type owl:ObjectProperty ,
                              owl:SymmetricProperty ;
                     rdfs:domain music:Genre ;
                     rdfs:range music:Genre .


###  http://example.org/music#recommendedWith
music:recommendedWith rdf:type owl:ObjectProperty ,
                               owl:SymmetricProperty ;
                      rdfs:domain music:Song ;
                      rdfs:range music:Song .


#################################################################
#    Additional Data Properties
#################################################################

###  http://example.org/music#bpm
music:bpm rdf:type owl:DatatypeProperty ;
          rdfs:domain music:Song ;
          rdfs:range xsd:integer .


###  http://example.org/music#durationSeconds
music:durationSeconds rdf:type owl:DatatypeProperty ;
                      rdfs:domain music:Song ;
                      rdfs:range xsd:integer .


###  http://example.org/music#explicitFlag
music:explicitFlag rdf:type owl:DatatypeProperty ;
                   rdfs:domain music:Song ;
                   rdfs:range xsd:boolean .


###  http://example.org/music#popularityScore
music:popularityScore rdf:type owl:DatatypeProperty ;
                      rdfs:domain music:Song ;
                      rdfs:range xsd:decimal .


###  http://example.org/music#eventDate
music:eventDate rdf:type owl:DatatypeProperty ;
                rdfs:domain music:Event ;
                rdfs:range xsd:date .


###  http://example.org/music#title
music:title rdf:type owl:DatatypeProperty ;
            rdfs:domain music:Event ;
            rdfs:range xsd:string .


#################################################################
#    SWRL Rules
#################################################################

music:varSongA rdf:type swrl:Variable ;
               swrl:varName "songA" .

music:varSongB rdf:type swrl:Variable ;
               swrl:varName "songB" .

music:varArtist rdf:type swrl:Variable ;
                swrl:varName "artist" .

music:varGenre rdf:type swrl:Variable ;
               swrl:varName "genre" .

music:varGenreB rdf:type swrl:Variable ;
                swrl:varName "genreB" .

music:varCountry rdf:type swrl:Variable ;
                 swrl:varName "country" .

music:varEvent rdf:type swrl:Variable ;
               swrl:varName "event" .

music:varAlbum rdf:type swrl:Variable ;
               swrl:varName "album" .

music:varArtistB rdf:type swrl:Variable ;
                 swrl:varName "artistB" .

music:varYear rdf:type swrl:Variable ;
              swrl:varName "year" .

music:varScore rdf:type swrl:Variable ;
               swrl:varName "score" .

music:varDuration rdf:type swrl:Variable ;
                  swrl:varName "duration" .

music:varMood rdf:type swrl:Variable ;
              swrl:varName "mood" .

music:rule_relatedBySharedArtist rdf:type swrl:Imp ;
                                 rdfs:label "Songs with same performer are relatedByArtist" ;
                                 swrl:body ( [ rdf:type swrl:IndividualPropertyAtom ;
                                               swrl:propertyPredicate music:performedBy ;
                                               swrl:argument1 music:varSongA ;
                                               swrl:argument2 music:varArtist
                                             ]
                                             [ rdf:type swrl:IndividualPropertyAtom ;
                                               swrl:propertyPredicate music:performedBy ;
                                               swrl:argument1 music:varSongB ;
                                               swrl:argument2 music:varArtist
                                             ]
                                             [ rdf:type swrl:DifferentIndividualsAtom ;
                                               swrl:argument1 music:varSongA ;
                                               swrl:argument2 music:varSongB
                                             ]
                                           ) ;
                                 swrl:head ( [ rdf:type swrl:IndividualPropertyAtom ;
                                               swrl:propertyPredicate music:relatedByArtist ;
                                               swrl:argument1 music:varSongA ;
                                               swrl:argument2 music:varSongB
                                             ]
                                           ) .


music:rule_propagateGenreForRelatedSongs rdf:type swrl:Imp ;
                                         rdfs:label "Related songs inherit genre context" ;
                                         swrl:body ( [ rdf:type swrl:IndividualPropertyAtom ;
                                                       swrl:propertyPredicate music:relatedByArtist ;
                                                       swrl:argument1 music:varSongA ;
                                                       swrl:argument2 music:varSongB
                                                     ]
                                                     [ rdf:type swrl:IndividualPropertyAtom ;
                                                       swrl:propertyPredicate music:hasGenre ;
                                                       swrl:argument1 music:varSongA ;
                                                       swrl:argument2 music:varGenre
                                                     ]
                                                   ) ;
                                         swrl:head ( [ rdf:type swrl:IndividualPropertyAtom ;
                                                       swrl:propertyPredicate music:hasGenre ;
                                                       swrl:argument1 music:varSongB ;
                                                       swrl:argument2 music:varGenre
                                                     ]
                                                   ) .


music:rule_eventCountryFromArtistOrigin rdf:type swrl:Imp ;
                                        rdfs:label "Event country inferred from artist origin" ;
                                        swrl:body ( [ rdf:type swrl:IndividualPropertyAtom ;
                                                      swrl:propertyPredicate <http://example.invalid/ontologies/ont.owl#performsAt> ;
                                                      swrl:argument1 music:varArtist ;
                                                      swrl:argument2 music:varEvent
                                                    ]
                                                    [ rdf:type swrl:IndividualPropertyAtom ;
                                                      swrl:propertyPredicate music:fromCountry ;
                                                      swrl:argument1 music:varArtist ;
                                                      swrl:argument2 music:varCountry
                                                    ]
                                                  ) ;
                                        swrl:head ( [ rdf:type swrl:IndividualPropertyAtom ;
                                                      swrl:propertyPredicate music:hostCountry ;
                                                      swrl:argument1 music:varEvent ;
                                                      swrl:argument2 music:varCountry
                                                    ]
                                                  ) .


music:rule_albumByArtistFromSongs rdf:type swrl:Imp ;
                                  rdfs:label "Infer albumByArtist from songs in album" ;
                                  swrl:body ( [ rdf:type swrl:IndividualPropertyAtom ;
                                                swrl:propertyPredicate music:partOfAlbum ;
                                                swrl:argument1 music:varSongA ;
                                                swrl:argument2 music:varAlbum
                                              ]
                                              [ rdf:type swrl:IndividualPropertyAtom ;
                                                swrl:propertyPredicate music:performedBy ;
                                                swrl:argument1 music:varSongA ;
                                                swrl:argument2 music:varArtist
                                              ]
                                            ) ;
                                  swrl:head ( [ rdf:type swrl:IndividualPropertyAtom ;
                                                swrl:propertyPredicate music:albumByArtist ;
                                                swrl:argument1 music:varAlbum ;
                                                swrl:argument2 music:varArtist
                                              ]
                                            ) .


music:rule_albumPrimaryGenreFromSongs rdf:type swrl:Imp ;
                                      rdfs:label "Infer albumPrimaryGenre from song genres" ;
                                      swrl:body ( [ rdf:type swrl:IndividualPropertyAtom ;
                                                    swrl:propertyPredicate music:partOfAlbum ;
                                                    swrl:argument1 music:varSongA ;
                                                    swrl:argument2 music:varAlbum
                                                  ]
                                                  [ rdf:type swrl:IndividualPropertyAtom ;
                                                    swrl:propertyPredicate music:hasGenre ;
                                                    swrl:argument1 music:varSongA ;
                                                    swrl:argument2 music:varGenre
                                                  ]
                                                ) ;
                                      swrl:head ( [ rdf:type swrl:IndividualPropertyAtom ;
                                                    swrl:propertyPredicate music:albumPrimaryGenre ;
                                                    swrl:argument1 music:varAlbum ;
                                                    swrl:argument2 music:varGenre
                                                  ]
                                                ) .


music:rule_artistCollaborationFromDuet rdf:type swrl:Imp ;
                                       rdfs:label "Infer collaboratesWith from duet song" ;
                                       swrl:body ( [ rdf:type swrl:IndividualPropertyAtom ;
                                                     swrl:propertyPredicate music:performedBy ;
                                                     swrl:argument1 music:varSongA ;
                                                     swrl:argument2 music:varArtist
                                                   ]
                                                   [ rdf:type swrl:IndividualPropertyAtom ;
                                                     swrl:propertyPredicate music:performedBy ;
                                                     swrl:argument1 music:varSongA ;
                                                     swrl:argument2 music:varArtistB
                                                   ]
                                                   [ rdf:type swrl:DifferentIndividualsAtom ;
                                                     swrl:argument1 music:varArtist ;
                                                     swrl:argument2 music:varArtistB
                                                   ]
                                                 ) ;
                                       swrl:head ( [ rdf:type swrl:IndividualPropertyAtom ;
                                                     swrl:propertyPredicate music:collaboratesWith ;
                                                     swrl:argument1 music:varArtist ;
                                                     swrl:argument2 music:varArtistB
                                                   ]
                                                 ) .


music:rule_collaborativeArtistClass rdf:type swrl:Imp ;
                                    rdfs:label "Artist with collaboration is CollaborativeArtist" ;
                                    swrl:body ( [ rdf:type swrl:IndividualPropertyAtom ;
                                                  swrl:propertyPredicate music:collaboratesWith ;
                                                  swrl:argument1 music:varArtist ;
                                                  swrl:argument2 music:varArtistB
                                                ]
                                              ) ;
                                    swrl:head ( [ rdf:type swrl:ClassAtom ;
                                                  swrl:classPredicate music:CollaborativeArtist ;
                                                  swrl:argument1 music:varArtist
                                                ]
                                              ) .


music:rule_multiGenreAlbumClass rdf:type swrl:Imp ;
                                rdfs:label "Album with >1 inferred genre is MultiGenreAlbum" ;
                                swrl:body ( [ rdf:type swrl:IndividualPropertyAtom ;
                                              swrl:propertyPredicate music:albumPrimaryGenre ;
                                              swrl:argument1 music:varAlbum ;
                                              swrl:argument2 music:varGenre
                                            ]
                                            [ rdf:type swrl:IndividualPropertyAtom ;
                                              swrl:propertyPredicate music:albumPrimaryGenre ;
                                              swrl:argument1 music:varAlbum ;
                                              swrl:argument2 music:varGenreB
                                            ]
                                            [ rdf:type swrl:DifferentIndividualsAtom ;
                                              swrl:argument1 music:varGenre ;
                                              swrl:argument2 music:varGenreB
                                            ]
                                          ) ;
                                swrl:head ( [ rdf:type swrl:ClassAtom ;
                                              swrl:classPredicate music:MultiGenreAlbum ;
                                              swrl:argument1 music:varAlbum
                                            ]
                                          ) .


music:rule_classicSongByYear rdf:type swrl:Imp ;
                             rdfs:label "Songs released <= 2005 are ClassicSong" ;
                             swrl:body ( [ rdf:type swrl:ClassAtom ;
                                           swrl:classPredicate music:Song ;
                                           swrl:argument1 music:varSongA
                                         ]
                                         [ rdf:type swrl:DatavaluedPropertyAtom ;
                                           swrl:propertyPredicate music:releaseYear ;
                                           swrl:argument1 music:varSongA ;
                                           swrl:argument2 music:varYear
                                         ]
                                         [ rdf:type swrl:BuiltinAtom ;
                                           swrl:builtin swrlb:lessThanOrEqual ;
                                           swrl:arguments ( music:varYear 2005 )
                                         ]
                                       ) ;
                             swrl:head ( [ rdf:type swrl:ClassAtom ;
                                           swrl:classPredicate music:ClassicSong ;
                                           swrl:argument1 music:varSongA
                                         ]
                                       ) .


music:rule_trendingSongByPopularity rdf:type swrl:Imp ;
                                    rdfs:label "Songs with popularity > 80 are TrendingSong" ;
                                    swrl:body ( [ rdf:type swrl:ClassAtom ;
                                                  swrl:classPredicate music:Song ;
                                                  swrl:argument1 music:varSongA
                                                ]
                                                [ rdf:type swrl:DatavaluedPropertyAtom ;
                                                  swrl:propertyPredicate music:popularityScore ;
                                                  swrl:argument1 music:varSongA ;
                                                  swrl:argument2 music:varScore
                                                ]
                                                [ rdf:type swrl:BuiltinAtom ;
                                                  swrl:builtin swrlb:greaterThan ;
                                                  swrl:arguments ( music:varScore "80"^^xsd:decimal )
                                                ]
                                              ) ;
                                    swrl:head ( [ rdf:type swrl:ClassAtom ;
                                                  swrl:classPredicate music:TrendingSong ;
                                                  swrl:argument1 music:varSongA
                                                ]
                                              ) .


music:rule_hitSongByPopularityAndDuration rdf:type swrl:Imp ;
                                          rdfs:label "Trending songs with duration > 180 are HitSong" ;
                                          swrl:body ( [ rdf:type swrl:ClassAtom ;
                                                        swrl:classPredicate music:TrendingSong ;
                                                        swrl:argument1 music:varSongA
                                                      ]
                                                      [ rdf:type swrl:DatavaluedPropertyAtom ;
                                                        swrl:propertyPredicate music:durationSeconds ;
                                                        swrl:argument1 music:varSongA ;
                                                        swrl:argument2 music:varDuration
                                                      ]
                                                      [ rdf:type swrl:BuiltinAtom ;
                                                        swrl:builtin swrlb:greaterThan ;
                                                        swrl:arguments ( music:varDuration 180 )
                                                      ]
                                                    ) ;
                                          swrl:head ( [ rdf:type swrl:ClassAtom ;
                                                        swrl:classPredicate music:HitSong ;
                                                        swrl:argument1 music:varSongA
                                                      ]
                                                    ) .


music:rule_recommendationByMood rdf:type swrl:Imp ;
                                rdfs:label "Songs with the same mood are recommendedWith" ;
                                swrl:body ( [ rdf:type swrl:IndividualPropertyAtom ;
                                              swrl:propertyPredicate music:hasMood ;
                                              swrl:argument1 music:varSongA ;
                                              swrl:argument2 music:varMood
                                            ]
                                            [ rdf:type swrl:IndividualPropertyAtom ;
                                              swrl:propertyPredicate music:hasMood ;
                                              swrl:argument1 music:varSongB ;
                                              swrl:argument2 music:varMood
                                            ]
                                            [ rdf:type swrl:DifferentIndividualsAtom ;
                                              swrl:argument1 music:varSongA ;
                                              swrl:argument2 music:varSongB
                                            ]
                                          ) ;
                                swrl:head ( [ rdf:type swrl:IndividualPropertyAtom ;
                                              swrl:propertyPredicate music:recommendedWith ;
                                              swrl:argument1 music:varSongA ;
                                              swrl:argument2 music:varSongB
                                            ]
                                          ) .


